# =========================================================================
# AWS RDS PostgreSQL CONNECTION CONFIGURATION TEMPLATE
# =========================================================================
# Rename this file to '.env' and fill in your actual AWS RDS credentials.
# Make sure NOT to commit the '.env' file to your Git repository!

# PostgreSQL Connection URL format:
# postgresql://<username>:<password>@<aws-rds-endpoint>:<port>/<database-name>
# Example:
# DATABASE_URL=postgresql://postgres:mysecurepassword@mydb.c123456789.us-east-1.rds.amazonaws.com:5432/devops_db

DATABASE_URL=postgresql://<db_username>:<db_password>@<aws_rds_endpoint>:5432/<db_name>
